# Borderless Environment Variables
# Copy this file to backend/functions/.env and fill in values

# Google AI / Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Firebase (auto-configured via google-services.json for Android)
FIREBASE_PROJECT_ID=your-firebase-project-id

# API Configuration
API_BASE_URL=https://us-central1-your-project.cloudfunctions.net/api

# Feature Flags
ENABLE_TRANSLATION=true
ENABLE_QA=true
MAX_ALERTS_PER_NOTIFICATION=2
NOTIFICATION_SUPPRESSION_HOURS=24
